{
  "name": "quickchat",
  "version": "1.0.0",
  "description": "Real-time messaging app with temporary chat rooms",
  "main": "server/index.js",
  "scripts": {
    "server": "node server/index.js",
    "client": "cd client && npm start",
    "install-all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
